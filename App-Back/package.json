{
  "name": "app-back",
  "version": "0.1.0",
  "private": true,
  "description": "Back del TFM",
  "license": "ISC",
  "author": "Sergio Sanisidro",
  "type": "commonjs",
  "main": "build/src/apps/backend/server.js",
  "scripts": {
    "build": "tsc -p . && npm run copy-assets",
    "build:tsc": "tsc -p tsconfig.prod.json",
    "build:di": "copy 'src/**/*.{json,yaml,html,png}' build/src",
    "build:clean": "rm -r build; exit 0",
    "test": "npm run test:unit && npm run test:features",
    "test:unit": "cross-env NODE_ENV=test jest",
    "test:features": "cross-env NODE_ENV=test jest --config=jest.features.config.js",
    "test:e2e": "jest --config=jest.e2e.config.js",
    "dev": "ts-node-dev --ignore-watch node_modules ./src/apps/backend/start.ts",
    "copy-assets": "shx cp -r src/apps/backend/dependency-injection build/src/apps/backend/ && shx cp -r src/Contexts/Shared/infrastructure/config build/src/Contexts/Shared/infrastructure/",
    "lint": "echo \"No linter configured\"",
    "seed:crops": "ts-node src/db/seed/crops/index.ts"
  },
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/errorhandler": "^1.5.3",
    "@types/express-promise-router": "^2.0.1",
    "@types/helmet": "^0.0.48",
    "@types/http-status": "^0.2.30",
    "@types/jsonwebtoken": "^9.0.10",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "convict": "^6.2.5",
    "cors": "^2.8.6",
    "dotenv": "^16.0.3",
    "errorhandler": "^1.5.2",
    "express": "^4.18.2",
    "express-promise-router": "^4.1.1",
    "express-validator": "^7.3.1",
    "glob": "^13.0.2",
    "helmet": "^8.1.0",
    "http-status": "^2.1.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "module-alias": "^2.3.4",
    "node-cron": "^3.0.3",
    "node-dependency-injection": "^2.7.3",
    "pg": "^8.18.0",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/convict": "^6.1.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.33",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.6.6",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "shx": "^0.4.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2"
  }
}
